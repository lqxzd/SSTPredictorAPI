# -----------------------------------------------------------
# 1. 用户自定义要求
# -----------------------------------------------------------

# 过滤所有 .nc 后缀的文件 (NetCDF 数据文件)
*.nc

# 过滤所有 __pycache__ 文件夹 (Python 字节码缓存)
__pycache__/

# 过滤 venv 虚拟环境文件夹
venv/
SSTPredEnv/

# -----------------------------------------------------------
# 2. Python 通用忽略项 (建议保留)
# -----------------------------------------------------------

# 编译生成的文件
*.py[cod]
*$py.class
*.so

# 构建分发文件
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
*.egg

# 安装清单
Pipfile.lock

# 调试日志
*.log

# 环境变量与敏感配置 (强烈建议忽略，防止密钥泄露)
.env
.venv

# 数据库文件 (如果使用 SQLite)
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------
# 3. IDE 与编辑器配置 (可选)
# -----------------------------------------------------------

# PyCharm / IntelliJ
.idea/

# VS Code
.vscode/

# Sublime Text
*.sublime-project
*.sublime-workspace

# macOS 系统文件 (如果在 Mac 上开发)
.DS_Store

# Windows 系统文件 (如果在 Windows 上开发)
Thumbs.db